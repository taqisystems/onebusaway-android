<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".KelantanBusApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="${APP_NAME}"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KelantanBus"
        android:usesCleartextTraffic="false">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.KelantanBus"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${GOOGLE_MAPS_API_KEY}" />

        <!-- OneSignal SDK 5.x: icon resolved by drawable name "ic_stat_onesignal_default" (no manifest key) -->
        <!-- OneSignal SDK 5.x: accent color key is .DEFAULT suffix -->
        <meta-data
            android:name="com.onesignal.NotificationAccentColor.DEFAULT"
            android:value="C62828" />
        <!-- OneSignal: save every received notification to the in-app inbox -->
        <meta-data
            android:name="com.onesignal.NotificationServiceExtension"
            android:value="com.taqisystems.bus.android.data.KelantanBusNotificationExtension" />

        <!-- Cleans up in-app inbox when a notification is dismissed from the system tray -->
        <receiver
            android:name=".data.receiver.NotificationDeleteReceiver"
            android:exported="false" />

        <!-- Destination alert foreground service -->
        <service
            android:name=".service.DestinationAlertService"
            android:foregroundServiceType="location"
            android:exported="false" />
    </application>

</manifest>
